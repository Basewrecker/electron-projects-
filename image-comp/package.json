{
  "name": "image-comp",
  "productname": "image-comp",
  "version": "1.0.0",
  "description": "Compress images",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --exec electron .",
    "package-mac": "electron-packager . --overwrite --platform=darwin --arch=x64 --icon=assets/icons/mac/icon.icns --prune=true --out=release-builds",
    "package-win": "electron-packager .  --overwrite --asar=true --platform=win32 --arch=ia32 --icon=assets/icons/win/icon.ico --prune=false --out=release-builds --version-string.CompanyName=CE --version-string.FileDescription=CE --version-string.ProductName=\"ImageComp\"",    
    "package-linux": "electron-packager . --overwrite --platform=linux --arch=x64 --icon=assets/icons/png/1024x1024.png --prune=false --out=release-builds"
  },
  "author": "Rs",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-packager": "^17.1.2",
    "electron-reloader": "^1.2.3"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "imagemin": "^7.0.1",
    "imagemin-mozjpeg": "^9.0.0",
    "imagemin-pngquant": "^8.0.0",
    "mozjpeg": "^8.0.0",
    "nodemon": "^3.1.14",
    "slash": "^3.0.0"
  }
}
